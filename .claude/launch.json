{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 1420,
      "autoPort": false
    },
    {
      "name": "dashboard-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5199", "--strictPort"],
      "port": 5199
    },
    {
      "name": "website",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "website", "-l", "4173"],
      "port": 4173
    }
  ]
}
